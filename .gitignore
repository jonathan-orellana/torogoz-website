# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Environment variables — never commit secrets
.env
.env.*
!.env.example
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db

# Large raw video files — keep only compressed versions
public/assets/videos/*.MOV
public/assets/videos/*.mov
public/assets/videos/*.webm

# Original uncompressed images
public/assets/images/150139.png
